# Streamlit Cloud — Secrets Template
# 
# HOW TO USE:
# 1. Go to https://share.streamlit.io and connect your GitHub repo
# 2. In App Settings → Secrets, paste the content below with your real values
# 3. Streamlit Cloud will inject these as environment variables at runtime

GROQ_API_KEY = "your-groq-api-key-here"
OPENAI_API_KEY = "your-openai-api-key-here"
GEMINI_API_KEY = "your-gemini-api-key-here"

# Database — Streamlit Cloud uses SQLite by default (no config needed)
# For production PostgreSQL, set:
# DATABASE_URL = "postgresql+psycopg2://user:pass@host:5432/dbname"

DATABASE_URL = "sqlite:///./financial_ai.db"
