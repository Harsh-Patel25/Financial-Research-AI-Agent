# Environment Variables
# Replace these with your actual keys
ALPHA_VANTAGE_KEY=
NEWS_API_KEY=
FRGEMINI_API_KEY="your_gemini_key_here"
NEWS_API_KEY="your_news_api_key_here"

# ── LangSmith Tracing ────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT="financial-research-agent"
LANGCHAIN_API_KEY="your_langsmith_api_key_here"
FRED_API_KEY=
CRYPTOPANIC_API_KEY=
FMP_API_KEY=
ANGLE_ONE_API_KEY=

DATABASE_URL=

# ── Vector Database (Pinecone) ────────────────────────────────────
# Shared across the team — get the key from your team lead or Pinecone dashboard.
# https://app.pinecone.io → API Keys
# Leave blank to fall back to local ChromaDB (offline / solo dev only).
Pinecone_Vector_Database=your_pinecone_api_key_here
